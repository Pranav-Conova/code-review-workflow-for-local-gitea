# Claude OAuth credentials
# Get these from: cat ~/.claude/.credentials.json → claudeAiOauth object
CLAUDE_TOKEN=sk-ant-oat01-your-access-token-here
CLAUDE_REFRESH_TOKEN=your-refresh-token-here

# Gitea
# Generate at: <your-gitea-host>/user/settings/applications
GITEA_TOKEN=your-gitea-access-token
GITEA_HOST=http://localhost:3000

# Optional
POLL_INTERVAL=10
MAX_CONCURRENT_REVIEWS=2
